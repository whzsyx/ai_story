# Django
DJANGO_SECRET_KEY=your-secret-key-here
DJANGO_SETTINGS_MODULE=config.settings.development
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# 数据库
DATABASE_URL=sqlite:///db.sqlite3

# Redis
REDIS_URL=redis://localhost:6379/5
REDIS_HOST=localhost
REDIS_PORT=6379

# Celery
CELERY_BROKER_URL=redis://localhost:6379/5
CELERY_RESULT_BACKEND=redis://localhost:6379/5

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:8080,http://localhost:3000

# Page Agent / OpenCode
AGENT_SERVER_BASE_URL=http://127.0.0.1:9002
AGENT_SERVER_USERNAME=opencode
AGENT_SERVER_PASSWORD=
MCP_ACCESS_TOKEN=
AGENT_MODEL_PROVIDER_ID=opencode
AGENT_MODEL_ID=big-pickle
AGENT_MODEL_VARIANT=
AGENT_REMOTE_AGENT_NAME=build
AGENT_SHOW_FREE_MODELS=false

# Closed-source backend apps (local dev only)
# Point to the private repo's backend/apps directory. Example:
# PRIVATE_BACKEND_APPS_ROOT=/absolute/path/to/ai_story_private/backend/apps
PRIVATE_BACKEND_APPS_ROOT=
